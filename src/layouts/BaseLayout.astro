---
// Augova — base document shell (Milestone 2, extended in Milestone 3).
// Owns <head> (charset, viewport, self-hosted font preloads, JSON-LD slot)
// and the persistent chrome: Header → <main> → Footer + sticky mobile CTA.
// Does NOT own <h1> — every page supplies exactly one itself (spec §4).
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";

interface Props {
  title: string;
  description?: string;
  /** Defaults to /og/default.png — a real file must always exist here so
   *  og:image never 404s (spec §12). */
  ogImage?: string;
  /** Keep dev/preview pages (e.g. /styleguide) out of search results. */
  noindex?: boolean;
  /** Homepage sets this true so the header floats transparent over the dark
   *  hero and solidifies on scroll. Every other page: solid from the top. */
  transparentHeader?: boolean;
  /** Render WITHOUT site chrome (no header/footer/CTA) — used by the dev
   *  styleguide so it stays a pure component preview with its own <main>. */
  bare?: boolean;
}

const {
  title,
  description,
  ogImage = "/og/default.png",
  noindex = false,
  transparentHeader = false,
  bare = false,
} = Astro.props;

// Cloudflare Web Analytics (spec §11) — cookieless pageview beacon, no
// consent banner needed. [[PLACEHOLDER]] until the site has a real CF
// Pages deployment/token; the tag is skipped entirely if unset so no
// broken/empty beacon call ships.
const cfBeaconToken = import.meta.env.CF_WEB_ANALYTICS_TOKEN;

// Canonical + OG/Twitter (spec §12). Astro.site is the configured production
// domain (astro.config.mjs); Astro.url.pathname keeps query/hash off canonical.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// LocalBusiness + Service JSON-LD (spec §12) — rendered site-wide from
// BaseLayout, not per-page, since it describes the business itself. York
// Region areaServed per spec. Canadian framing only — no HIPAA/SOC2/US
// claims, no pricing (hard rules, §4).
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Augova",
  url: Astro.site?.toString(),
  areaServed: [
    "Richmond Hill",
    "Markham",
    "Vaughan",
    "Aurora",
    "Newmarket",
    "Barrie",
  ].map((name) => ({ "@type": "City", name })),
  address: {
    "@type": "PostalAddress",
    addressRegion: "ON",
    addressCountry: "CA",
  },
  makesOffer: {
    "@type": "Offer",
    itemOffered: {
      "@type": "Service",
      name: "AI Voice Receptionist",
      description:
        "A managed AI voice receptionist that answers, books, and follows up on every business call.",
      areaServed: "York Region, Ontario, Canada",
    },
  },
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph + Twitter card (spec §12) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Augova" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Self-hosted font preloads (M2): only the two above-the-fold weights. -->
    <link
      rel="preload"
      href="/fonts/inter-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- Per-page structured data (e.g. FAQPage) can extend via this slot. -->
    <slot name="jsonld" />

    <title>{title}</title>

    {
      cfBeaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${cfBeaconToken}"}`}
        />
      )
    }
  </head>
  <body>
    {
      bare ? (
        <main>
          <slot />
        </main>
      ) : (
        <Fragment>
          <Header transparent={transparentHeader} />
          <main>
            <slot />
          </main>
          <Footer />
          <StickyMobileCTA />
        </Fragment>
      )
    }
  </body>
</html>

<script>
  // Delegated demo_cta_click (spec §11) — one listener for every Button
  // that carries data-analytics-section, instead of wiring each static
  // Button instance individually.
  import { track } from "../lib/analytics";

  document.addEventListener("click", (e) => {
    const trigger = (e.target as HTMLElement)?.closest<HTMLElement>("[data-analytics-section]");
    if (trigger) {
      track("demo_cta_click", { section: trigger.dataset.analyticsSection ?? "" });
    }
  });
</script>

<script>
  // Animation pass (spec §10) — both drivers are safe no-ops on pages/sections
  // with no matching elements, so they're loaded once, site-wide, here.
  import "../lib/reveal.js";
  import "../lib/parallax.js";
</script>
