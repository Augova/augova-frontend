---
// Augova — base document shell (Milestone 2, extended in Milestone 3).
// Owns <head> (charset, viewport, self-hosted font preloads, JSON-LD slot)
// and the persistent chrome: Header → <main> → Footer + sticky mobile CTA.
// Does NOT own <h1> — every page supplies exactly one itself (spec §4).
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";

interface Props {
  title: string;
  description?: string;
  /** Keep dev/preview pages (e.g. /styleguide) out of search results. */
  noindex?: boolean;
  /** Homepage sets this true so the header floats transparent over the dark
   *  hero and solidifies on scroll. Every other page: solid from the top. */
  transparentHeader?: boolean;
  /** Render WITHOUT site chrome (no header/footer/CTA) — used by the dev
   *  styleguide so it stays a pure component preview with its own <main>. */
  bare?: boolean;
}

const {
  title,
  description,
  noindex = false,
  transparentHeader = false,
  bare = false,
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Self-hosted font preloads (M2): only the two above-the-fold weights. -->
    <link
      rel="preload"
      href="/fonts/inter-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Structured data — pages inject via this slot (empty until SEO, M11). -->
    <slot name="jsonld" />

    <title>{title}</title>
  </head>
  <body>
    {
      bare ? (
        <main>
          <slot />
        </main>
      ) : (
        <Fragment>
          <Header transparent={transparentHeader} />
          <main>
            <slot />
          </main>
          <Footer />
          <StickyMobileCTA />
        </Fragment>
      )
    }
  </body>
</html>
