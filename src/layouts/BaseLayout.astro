---
// Augova — base document shell (Milestone 2).
// Owns <head>: charset, viewport, self-hosted font preloads, global.css.
// Does NOT own <h1> — every page supplies exactly one itself (spec §4).
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** Dev-preview pages (e.g. /styleguide) set this to keep them out of
   * search results without needing a separate robots.txt entry. */
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Self-hosted font preloads. Only the two weights used above the
         fold (regular body copy + semibold display headings) are
         preloaded — 500/mono load lazily behind font-display: swap. -->
    <link
      rel="preload"
      href="/fonts/inter-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
