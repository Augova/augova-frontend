---
// Dev-only visual verification page for Milestone 2 tokens/components.
// noindex, not linked from any nav/sitemap — internal use only.
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";

const swatches: { name: string; token: string; class: string }[] = [
  { name: "black", token: "--black", class: "bg-black" },
  { name: "ink", token: "--ink", class: "bg-ink" },
  { name: "gray-900", token: "--gray-900", class: "bg-gray-900" },
  { name: "gray-700", token: "--gray-700", class: "bg-gray-700" },
  { name: "gray-500", token: "--gray-500", class: "bg-gray-500" },
  { name: "gray-300", token: "--gray-300", class: "bg-gray-300" },
  { name: "gray-100", token: "--gray-100", class: "bg-gray-100" },
  { name: "paper", token: "--paper", class: "bg-paper border border-gray-300" },
  { name: "white", token: "--white", class: "bg-white border border-gray-300" },
];
---

<BaseLayout title="Styleguide — Augova (dev)" noindex={true}>
  <main class="mx-auto max-w-container px-gutter-mobile md:px-gutter py-16">
    <h1 class="text-h2-mobile md:text-h2-desktop mb-12">
      Styleguide <span class="text-small text-gray-500">(dev preview — not in nav)</span>
    </h1>

    <!-- ============================== TYPE ROLES ============================== -->
    <section class="mb-16">
      <h2 class="font-mono uppercase text-eyebrow text-gray-500 mb-6">Type roles</h2>

      <div class="mb-10">
        <p class="font-mono uppercase text-eyebrow text-gray-500 mb-2">
          hero — --text-hero-desktop / 72px / 600 / 1.05 / -0.02em
        </p>
        <p class="font-display text-hero-desktop">Managed voice, not software.</p>
      </div>

      <div class="mb-10">
        <p class="font-mono uppercase text-eyebrow text-gray-500 mb-2">
          h2 — --text-h2-desktop / 52px / 600 / 1.1 / -0.01em
        </p>
        <p class="font-display text-h2-desktop">Every call answered, every time.</p>
      </div>

      <div class="mb-10">
        <p class="font-mono uppercase text-eyebrow text-gray-500 mb-2">
          card-title — --text-card-title-desktop / 24px / 600 / 1.3 / -0.005em
        </p>
        <p class="font-display text-card-title-desktop">30-day proof window</p>
      </div>

      <div class="mb-10">
        <p class="font-mono uppercase text-eyebrow text-gray-500 mb-2">
          lead — --text-lead-desktop / 20px / 400 / 1.5 / 0em
        </p>
        <p class="font-body text-lead-desktop">
          A managed AI voice receptionist for GTA / York Region small businesses —
          answering every call so you never miss a customer again.
        </p>
      </div>

      <div class="mb-10">
        <p class="font-mono uppercase text-eyebrow text-gray-500 mb-2">
          body — --text-body-desktop / 18px / 400 / 1.55 / 0em
        </p>
        <p class="font-body text-body-desktop">
          Augova answers, qualifies, and books — in plain conversation, 24/7 — so
          calls turn into booked jobs instead of voicemail.
        </p>
      </div>

      <div class="mb-10">
        <p class="font-mono uppercase text-eyebrow text-gray-500 mb-2">
          label — --text-label-size / 15px / 500 / 1.2 / -0.005em
        </p>
        <p class="font-body text-label">Book a call</p>
      </div>

      <div class="mb-10">
        <p class="font-mono uppercase text-eyebrow text-gray-500 mb-2">
          small — --text-small-size / 13px / 400 / 1.45 / 0em
        </p>
        <p class="font-body text-small text-gray-700">
          PIPEDA-aligned. No pricing shown here — that's a sales conversation.
        </p>
      </div>

      <div class="mb-10">
        <p class="font-mono uppercase text-eyebrow text-gray-500 mb-2">
          eyebrow — --text-eyebrow-size / 11px / 500 / 0.14em / font-mono uppercase
        </p>
        <p class="font-mono uppercase text-eyebrow">Managed AI receptionist</p>
      </div>
    </section>

    <!-- ============================== BUTTONS ============================== -->
    <section class="mb-16">
      <h2 class="font-mono uppercase text-eyebrow text-gray-500 mb-6">
        Buttons — hover / focus-visible / active are live pseudo-states;
        tab to or hover each button to verify
      </h2>

      <div class="flex flex-wrap items-center gap-6 mb-6">
        <div>
          <p class="text-small text-gray-500 mb-2">primary / default</p>
          <Button variant="primary" href="#">Book a call</Button>
        </div>
        <div>
          <p class="text-small text-gray-500 mb-2">primary / disabled</p>
          <Button variant="primary" disabled>Book a call</Button>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-6">
        <div>
          <p class="text-small text-gray-500 mb-2">secondary / default</p>
          <Button variant="secondary" href="#">Learn more</Button>
        </div>
        <div>
          <p class="text-small text-gray-500 mb-2">secondary / disabled</p>
          <Button variant="secondary" disabled>Learn more</Button>
        </div>
      </div>
    </section>

    <!-- ============================== PALETTE ============================== -->
    <section>
      <h2 class="font-mono uppercase text-eyebrow text-gray-500 mb-6">
        Palette (monochrome — no signal token below)
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6">
        {
          swatches.map((s) => (
            <div>
              <div class={`h-16 rounded-card ${s.class}`} />
              <p class="text-small mt-2">{s.name}</p>
              <p class="text-small text-gray-500">{s.token}</p>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
