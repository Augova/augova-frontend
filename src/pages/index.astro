---
// Augova homepage (spec §7) — Milestone 5 sections + M6 animated hero.
// All 11 sections top-to-bottom with final copy from src/data + spec §7,
// alternating dark/light. The hero uses the M6 animated mesh-gradient island
// (MeshGradientHero) instead of the originally planned map. Scroll motion
// (count-up, typing, staggered reveals) and LeadForm wiring are still
// deferred. Exactly one <h1> (the hero). Fully monochrome — no --signal.
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
import StatCard from "../components/StatCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import IndustryCard from "../components/IndustryCard.astro";
import StepRow from "../components/StepRow.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import AudioDemoPlayer from "../components/AudioDemoPlayer.astro";
import LiveCallVisual from "../components/LiveCallVisual.astro";
import LeadForm from "../components/LeadForm.astro";
import HeroSection from "../components/HeroSection.astro";

import statsData from "../data/stats.json";
import featuresData from "../data/features.json";
import stepsData from "../data/steps.json";
import industriesData from "../data/industries.json";
import faqData from "../data/faq.json";
import demosData from "../data/demos.json";
import type { Stat, Feature, StepsData, Industry, Faq, Demo } from "../data/types";

const stats = statsData as Stat[];
const features = featuresData as Feature[];
const steps = stepsData as StepsData;
const industries = industriesData as Industry[];
const faqs = faqData as Faq[];
const demos = demosData as Demo[];

// §7.3 — four capability blocks (final copy).
const capabilities = [
  {
    title: "Answers every call",
    body: "Day, night, weekend, holiday, and overflow. No voicemail, no hold music.",
  },
  {
    title: "Understands real conversations",
    body: "Handles natural speech, interruptions, and background noise, and answers from your business's own information.",
  },
  {
    title: "Books and updates",
    body: "Checks availability, books on the call, sends confirmation, and updates your calendar and CRM.",
  },
  {
    title: "Escalates safely",
    body: "Sends urgent or sensitive calls to the right person, with a summary so no one repeats themselves.",
  },
];

// §7.5 — competitor/alternative cost anchors. Per spec §7.5 these figures are
// ALLOWED (market alternatives, never an Augova price). A caption reinforces it.
const roiAnchors = [
  { cost: "$325–825/mo", label: "After-hours answering service" },
  { cost: "$3,000+/mo", label: "Full-time front-desk hire, loaded" },
  { cost: "~$160K/yr", label: "Round-the-clock human coverage" },
];

// §7.7 — one greeting in four scripts. Wording is illustrative (not spec-final
// copy); refine with a native speaker before launch. Non-Latin scripts fall
// through to the system font (Inter's subset is Latin-only) — intended per §7.7.
const greetings = [
  { lang: "English", text: "Hello, thanks for calling. How can I help?" },
  { lang: "中文", text: "您好，感谢您的来电。有什么可以帮您？" },
  { lang: "فارسی", text: "سلام، از تماس شما متشکرم. چطور می‌توانم کمکتان کنم؟", rtl: true },
  { lang: "Русский", text: "Здравствуйте, спасибо за звонок. Чем могу помочь?" },
];
---

<BaseLayout
  title="Augova — AI voice receptionist"
  description="A managed AI voice receptionist for GTA / York Region small businesses. Every call answered around the clock, booked, and followed up — so the phone stops costing you customers."
  transparentHeader={true}
>
  {/* ---------- 7.1 Hero (dark) ---------- */}
  {/* Responsive hero: Fluffy Globe (three.js) on laptops/desktops, Mesh
      gradient on phones/tablets. Phones never download three.js. Both
      variants can be viewed in isolation at /hero-preview. */}
  <HeroSection variant="responsive" />

  {/* ---------- 7.2 Problem strip (dark) ---------- */}
  <Section theme="dark" eyebrow="The missed-call problem">
    <h2 class="font-display text-h2-mobile max-w-3xl md:text-h2-desktop">
      The phone is still where high-intent customers disappear.
    </h2>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat) => <StatCard stat={stat} />)}
    </div>
  </Section>

  {/* ---------- 7.3 Product intro (dark, #receptionist) ---------- */}
  <Section theme="dark" eyebrow="Our core product" id="receptionist">
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 class="font-display text-h2-mobile max-w-xl md:text-h2-desktop">
          Meet the Augova AI Voice Receptionist.
        </h2>
        <p class="font-body text-lead-mobile mt-5 max-w-xl text-gray-300 md:text-lead-desktop">
          It's not a voicemail replacement. It's a trained front desk that works
          inside your business rules.
        </p>
        <dl class="mt-10 grid gap-x-8 gap-y-8 sm:grid-cols-2">
          {
            capabilities.map((cap) => (
              <div>
                <dt class="font-display text-card-title-mobile text-paper">{cap.title}</dt>
                <dd class="font-body text-body-mobile mt-2 text-gray-300">{cap.body}</dd>
              </div>
            ))
          }
        </dl>
      </div>
      <LiveCallVisual />
    </div>
  </Section>

  {/* ---------- 7.4 Audio demo (dark, #demo-audio) ---------- */}
  <Section theme="dark" eyebrow="Hear it work" id="demo-audio">
    <h2 class="font-display text-h2-mobile max-w-3xl md:text-h2-desktop">
      This is Augova answering a real call.
    </h2>
    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      {demos.map((demo) => <AudioDemoPlayer demo={demo} />)}
    </div>
  </Section>

  {/* ---------- 7.5 ROI moment (light) ---------- */}
  <Section theme="light" eyebrow="Missed calls are missed revenue">
    <h2 class="font-display text-h2-mobile max-w-3xl md:text-h2-desktop">
      One recovered customer can pay for the whole month.
    </h2>
    <p class="font-body text-body-mobile mt-6 max-w-2xl text-gray-700 md:text-body-desktop">
      A phone call is where new customers ask, book, and decide who to trust.
      When it goes unanswered, most don't leave a message — they call the next
      business that picks up.
    </p>
    <div class="mt-10 grid gap-4 sm:grid-cols-3">
      {
        roiAnchors.map((a) => (
          <div class="rounded-card border border-gray-100 bg-white p-6">
            <p class="font-display text-card-title-desktop tabular-nums text-ink">{a.cost}</p>
            <p class="font-body text-body-mobile mt-2 text-gray-700">{a.label}</p>
          </div>
        ))
      }
    </div>
    <p class="font-mono text-small mt-3 text-gray-700">
      Typical market rates for alternatives — not Augova's pricing.
    </p>
    <p class="font-body text-body-mobile mt-8 max-w-2xl text-gray-700 md:text-body-desktop">
      Augova answers every call, day and night, for a flat monthly rate — and
      one captured job or patient can cover it.
    </p>
    <div class="mt-8">
      <Button variant="primary" href="/demo">Book Free Demo</Button>
    </div>
  </Section>

  {/* ---------- 7.6 What's included (light) ---------- */}
  <Section theme="light" eyebrow="What's included">
    <h2 class="font-display text-h2-mobile max-w-3xl md:text-h2-desktop">
      Everything your front desk does — and things it can't.
    </h2>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => <FeatureCard feature={feature} />)}
    </div>
  </Section>

  {/* ---------- 7.7 Multilingual (dark) ---------- */}
  <Section theme="dark" eyebrow="Speaks your customers' language">
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 class="font-display text-h2-mobile max-w-xl md:text-h2-desktop">
          It answers in Mandarin, Cantonese, Farsi, and more.
        </h2>
        <p class="font-body text-body-mobile mt-6 max-w-xl text-gray-300 md:text-body-desktop">
          In Richmond Hill, most residents' first language isn't English. Augova
          greets and serves callers in their own language — and can switch
          mid-call — so no customer is lost in translation. No answering service
          in the region does this.
        </p>
      </div>
      <ul class="flex flex-col gap-3">
        {
          greetings.map((g) => (
            <li class="rounded-card border border-gray-700 bg-gray-900 p-5">
              <p class="font-mono text-small mb-2 text-gray-500">{g.lang}</p>
              <p
                class="font-display text-card-title-mobile text-paper"
                lang={g.lang === "中文" ? "zh" : g.lang === "فارسی" ? "fa" : g.lang === "Русский" ? "ru" : "en"}
                dir={g.rtl ? "rtl" : undefined}
              >
                {g.text}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </Section>

  {/* ---------- 7.8 How it works + reliability (light, #how-it-works) ---------- */}
  <Section theme="light" eyebrow="How it works" id="how-it-works">
    <h2 class="font-display text-h2-mobile max-w-3xl md:text-h2-desktop">
      Launched for you — not another tool to figure out.
    </h2>
    <div class="mt-10 grid gap-12 lg:grid-cols-[1.4fr_1fr] lg:gap-16">
      <ol class="flex flex-col gap-6">
        {steps.steps.map((step) => <StepRow step={step} />)}
      </ol>
      <div class="rounded-card border border-gray-100 bg-white p-6">
        <h3 class="font-display text-card-title-mobile text-ink md:text-card-title-desktop">
          Reliable by design
        </h3>
        <ul class="mt-5 flex flex-wrap gap-2">
          {
            steps.reliability.map((item) => (
              <li class="font-mono text-small rounded-pill border border-gray-300 px-3 py-1 text-gray-700">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Section>

  {/* ---------- 7.9 Industries (dark, #industries) ---------- */}
  <Section theme="dark" eyebrow="Built for call-heavy businesses" id="industries">
    <h2 class="font-display text-h2-mobile max-w-3xl md:text-h2-desktop">
      If a missed call means a missed customer, this is for you.
    </h2>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {industries.map((industry) => <IndustryCard industry={industry} />)}
    </div>
  </Section>

  {/* ---------- 7.10 FAQ (light, #faq) ---------- */}
  <Section theme="light" eyebrow="Questions" id="faq">
    <h2 class="font-display text-h2-mobile mx-auto max-w-3xl text-center md:text-h2-desktop">
      Answers before you ask.
    </h2>
    <div class="mt-10">
      <FAQAccordion items={faqs} />
    </div>
  </Section>

  {/* ---------- 7.11 Final CTA (dark, full-bleed) ---------- */}
  <Section theme="dark" class="text-center">
    <h2 class="font-display text-h2-mobile mx-auto max-w-3xl md:text-h2-desktop">
      Let Augova answer your next missed call.
    </h2>
    <p class="font-body text-lead-mobile mx-auto mt-6 max-w-2xl text-gray-300 md:text-lead-desktop">
      Book a free demo and hear how it answers, books, and follows up for your
      business.
    </p>
    <div class="mt-8">
      <Button variant="inverted" href="/demo">Book Free Demo</Button>
    </div>
    <div class="mx-auto mt-12 max-w-xl border-t border-gray-700 pt-10">
      <p class="font-mono text-small mb-6 uppercase text-gray-500">Or request a callback</p>
      <LeadForm />
    </div>
  </Section>
</BaseLayout>
