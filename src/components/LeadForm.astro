---
// Augova — LeadForm (spec §7.11 fallback path; reused on /demo later).
// M5 renders the SHELL only: real fields, labels, autocomplete, and mobile
// keyboards, but submission is NOT wired — the Cloudflare Pages Function +
// Turnstile land in the forms milestone. Until then a tiny handler intercepts
// submit and points the user at the primary "Book Free Demo" path, so the form
// never does anything broken or misleading. Styled for the dark final-CTA
// section. One primary action lives outside this form (the Book Free Demo
// link); this is the secondary/inline path.
const fieldBase =
  "w-full min-h-11 rounded-input border border-gray-700 bg-ink px-4 py-2.5 font-body text-body-mobile text-paper placeholder:text-gray-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-paper";
const labelBase = "font-body text-label mb-1.5 block text-gray-300";
---

<form data-lead-form novalidate class="mx-auto flex max-w-xl flex-col gap-4 text-left">
  <div>
    <label for="lf-name" class={labelBase}>Name <span aria-hidden="true">*</span></label>
    <input id="lf-name" name="name" type="text" autocomplete="name" required class={fieldBase} />
  </div>

  <div>
    <label for="lf-business" class={labelBase}>Business name <span aria-hidden="true">*</span></label>
    <input id="lf-business" name="business" type="text" autocomplete="organization" required class={fieldBase} />
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label for="lf-email" class={labelBase}>Email <span aria-hidden="true">*</span></label>
      <input id="lf-email" name="email" type="email" autocomplete="email" inputmode="email" required class={fieldBase} />
    </div>
    <div>
      <label for="lf-phone" class={labelBase}>Phone <span aria-hidden="true">*</span></label>
      <input id="lf-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" required class={fieldBase} />
    </div>
  </div>

  <div>
    <label for="lf-details" class={labelBase}>How do you handle calls today?</label>
    <textarea id="lf-details" name="details" rows="3" class={`${fieldBase} resize-y`}></textarea>
  </div>

  <button
    type="submit"
    class="font-body text-label rounded-button min-h-11 select-none bg-paper px-6 text-ink transition-colors hover:bg-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-paper"
  >
    Request a callback
  </button>

  <p data-lead-status role="status" aria-live="polite" class="font-body text-small min-h-5 text-gray-300"></p>
</form>

<script>
  // M5 placeholder: the form isn't wired to a backend yet. Intercept submit,
  // keep the user's data on-page, and route them to the primary demo path.
  // Replaced by the real Pages Function handler in the forms milestone.
  document.querySelectorAll("[data-lead-form]").forEach((form) => {
    const status = form.querySelector("[data-lead-status]");
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      if (status) {
        status.textContent =
          "Thanks — online booking is coming soon. Please use “Book Free Demo” above and we’ll set up your demo call.";
      }
    });
  });
</script>
