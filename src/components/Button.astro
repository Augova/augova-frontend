---
// Augova — single monochrome Button (Milestone 2, spec §3/§7).
// Variants: primary (ink fill, for light sections), secondary (outline), and
// inverted (paper fill for the dark header/hero — spec §7.0 "solid white"
// Book Demo CTA). Still one component, still no --signal. Renders <a> when
// `href` is passed, otherwise <button>.

interface Props {
  variant?: "primary" | "secondary" | "inverted" | "outline-inverted";
  href?: string;
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  class?: string;
  /** Book Demo CTAs pass their section name (spec §11 `demo_cta_click`);
   *  a delegated listener in BaseLayout reads this attribute — Button
   *  itself stays a static component with no client JS of its own. */
  analyticsSection?: string;
}

const {
  variant = "primary",
  href,
  type = "button",
  disabled = false,
  class: className = "",
  analyticsSection,
} = Astro.props;

// min-h-11 = 2.75rem = 44px via Tailwind's default spacing scale (WCAG AA
// minimum touch target) — not an arbitrary literal.
// Hover lift (spec §10): translateY(-1px), CSS-only, collapses to nothing
// under prefers-reduced-motion via the global transition guard.
const base =
  "inline-flex items-center justify-center gap-2 min-h-11 px-6 " +
  "rounded-button text-label font-body select-none whitespace-nowrap " +
  "transition-[color,background-color,border-color,transform] duration-motion-min ease-augova " +
  "hover:-translate-y-px " +
  "disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:translate-y-0";

const variants = {
  // primary sits on light sections — dark fill, dark (ink) focus ring so the
  // ring is visible against the surrounding paper background.
  primary:
    "bg-ink text-paper " +
    "hover:bg-black active:bg-black active:opacity-90 " +
    "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink " +
    "disabled:hover:bg-ink",
  secondary:
    "bg-transparent text-ink border border-gray-300 " +
    "hover:border-ink hover:bg-gray-100 active:bg-gray-100 " +
    "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink " +
    "disabled:hover:border-gray-300 disabled:hover:bg-transparent",
  // inverted sits on the dark header/hero — paper fill, paper focus ring so
  // the ring is visible against the surrounding ink background (spec §7.0).
  inverted:
    "bg-paper text-ink " +
    "hover:bg-white active:bg-white active:opacity-90 " +
    "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-paper " +
    "disabled:hover:bg-paper",
  // outline-inverted is the secondary CTA on dark sections (e.g. the hero's
  // "Hear it answer a call"): transparent with a paper outline + paper ring.
  "outline-inverted":
    "bg-transparent text-paper border border-gray-500 " +
    "hover:border-paper hover:bg-white/10 active:bg-white/10 " +
    "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-paper " +
    "disabled:hover:border-gray-500 disabled:hover:bg-transparent",
};

const classes = [base, variants[variant], className].join(" ");
---

{
  href && !disabled ? (
    <a href={href} class={classes} data-analytics-section={analyticsSection}>
      <slot />
    </a>
  ) : (
    // A disabled <a> has no real HTML semantics without JS (it would still
    // navigate on click/Enter), so a disabled link renders as a disabled
    // <button> instead — same visual, correct semantics.
    <button
      type={type}
      class={classes}
      disabled={disabled}
      aria-disabled={disabled}
    >
      <slot />
    </button>
  )
}
