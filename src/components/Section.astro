---
// Augova — reusable section wrapper (spec §9). Owns section theme, an
// optional mono eyebrow, an anchor id, and consistent vertical rhythm +
// container width/gutters from tokens. Every M5 homepage section is built
// from this so spacing and theming stay uniform.
interface Props {
  theme?: "light" | "dark";
  eyebrow?: string;
  id?: string;
  class?: string;
}
const { theme = "light", eyebrow, id, class: className = "" } = Astro.props;

const themeClass = theme === "dark" ? "bg-ink text-paper" : "bg-paper text-ink";
// Eyebrow color is theme-aware: gray-500 clears AA on the dark ink background
// but not on light paper (2.9:1), so light sections use gray-700 (9.4:1).
const eyebrowColor = theme === "dark" ? "text-gray-500" : "text-gray-700";
---

<section id={id} class:list={[themeClass, "py-16 md:py-24", className]}>
  <div class="mx-auto max-w-container px-gutter-mobile md:px-gutter">
    {
      eyebrow && (
        <p
          class:list={["font-mono uppercase text-eyebrow mb-6", eyebrowColor]}
          data-parallax="0.05"
        >
          {eyebrow}
        </p>
      )
    }
    <slot />
  </div>
</section>
