---
// Augova — FeatureCard (spec §7.6 "What's included", light section).
// White card on paper for subtle elevation; title + body from features.json.
import type { Feature } from "../data/types";

interface Props {
  feature: Feature;
}
const { feature } = Astro.props;
---

<div class="flex flex-col rounded-card border border-gray-100 bg-white p-6">
  <h3 class="font-display text-card-title-mobile text-ink md:text-card-title-desktop">
    {feature.title}
  </h3>
  <p class="font-body text-body-mobile mt-3 text-gray-700 md:text-body-desktop">
    {feature.body}
  </p>
</div>
