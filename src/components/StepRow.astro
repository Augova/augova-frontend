---
// Augova — StepRow (spec §7.8 "How it works", light section).
// One numbered step. The ordinal is decorative (aria-hidden): the parent <ol>
// already conveys sequence to assistive tech. Rendered inside an <ol> by the
// section so the numbering is real, not faked.
import type { Step } from "../data/types";

interface Props {
  step: Step;
}
const { step } = Astro.props;
---

<li class="flex gap-5 md:gap-6">
  <span
    aria-hidden="true"
    class="font-mono text-card-title-mobile shrink-0 tabular-nums text-gray-500 md:text-card-title-desktop"
  >
    {step.n}
  </span>
  <div class="flex-1 border-b border-gray-100 pb-6">
    <h3 class="font-display text-card-title-mobile text-ink md:text-card-title-desktop">
      {step.title}
    </h3>
    <p class="font-body text-body-mobile mt-2 text-gray-700 md:text-body-desktop">
      {step.body}
    </p>
  </div>
</li>
