---
// Augova — AudioDemoPlayer (spec §7.4, dark section).
// Custom monochrome controls over a native <audio> element (native controls are
// non-monochrome and inconsistent across browsers, so we skin our own per §3
// while keeping the real media element for a11y + platform behavior). Audio
// files are [[PLACEHOLDER]] and may 404 — the control degrades gracefully
// (button disables on media error) so the section always looks finished.
import type { Demo } from "../data/types";

interface Props {
  demo: Demo;
}
const { demo } = Astro.props;
---

<div data-audio-player class="rounded-card border border-gray-700 bg-gray-900 p-5">
  <div class="flex items-center gap-4">
    <button
      type="button"
      data-audio-toggle
      data-label={demo.label}
      aria-label={`Play: ${demo.label}`}
      class="group grid size-11 shrink-0 place-items-center rounded-pill border border-gray-700 text-paper transition-colors hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-paper disabled:cursor-not-allowed disabled:opacity-40"
    >
      <svg data-icon-play aria-hidden="true" class="size-5 translate-x-px" viewBox="0 0 24 24" fill="currentColor">
        <path d="M8 5v14l11-7z" />
      </svg>
      <svg data-icon-pause aria-hidden="true" class="hidden size-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M6 5h4v14H6zM14 5h4v14h-4z" />
      </svg>
    </button>

    <div class="min-w-0 flex-1">
      <p class="font-body text-label text-paper">{demo.label}</p>
      <div class="mt-2 h-1 overflow-hidden rounded-pill bg-gray-700">
        <div data-audio-bar class="h-full w-0 bg-gray-300"></div>
      </div>
    </div>

    <span data-audio-time class="font-mono text-small shrink-0 tabular-nums text-gray-500">0:00</span>
  </div>

  <p class="font-body text-body-mobile rounded-input mt-4 border border-gray-700 p-4 text-gray-300">
    {demo.transcript}
  </p>

  <audio data-audio-el src={demo.audio} preload="none"></audio>
</div>

<script>
  import { track } from "../lib/analytics";

  // Hoisted once by Astro; wires every AudioDemoPlayer on the page.
  const fmt = (s: number) => {
    if (!isFinite(s)) return "0:00";
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60).toString().padStart(2, "0");
    return `${m}:${sec}`;
  };

  document.querySelectorAll<HTMLElement>("[data-audio-player]").forEach((root) => {
    const audio = root.querySelector<HTMLAudioElement>("[data-audio-el]");
    const btn = root.querySelector<HTMLButtonElement>("[data-audio-toggle]");
    const bar = root.querySelector<HTMLElement>("[data-audio-bar]");
    const time = root.querySelector<HTMLElement>("[data-audio-time]");
    const iconPlay = root.querySelector<HTMLElement>("[data-icon-play]");
    const iconPause = root.querySelector<HTMLElement>("[data-icon-pause]");
    if (!audio || !btn || !bar || !time || !iconPlay || !iconPause) return;

    const label = btn.dataset.label || "";
    const setPlaying = (playing: boolean) => {
      iconPlay.classList.toggle("hidden", playing);
      iconPause.classList.toggle("hidden", !playing);
      btn.setAttribute("aria-label", `${playing ? "Pause" : "Play"}: ${label}`);
    };

    btn.addEventListener("click", () => {
      if (audio.paused) {
        // One clip at a time across the whole page.
        document
          .querySelectorAll<HTMLAudioElement>("[data-audio-el]")
          .forEach((a) => { if (a !== audio) a.pause(); });
        audio.play().catch(() => { /* placeholder file missing — ignore */ });
      } else {
        audio.pause();
      }
    });

    audio.addEventListener("play", () => {
      setPlaying(true);
      track("audio_demo_play", { label });
    });
    audio.addEventListener("pause", () => setPlaying(false));
    audio.addEventListener("ended", () => {
      setPlaying(false);
      bar.style.width = "0%";
      time.textContent = "0:00";
      track("audio_demo_complete", { label });
    });
    audio.addEventListener("timeupdate", () => {
      const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      bar.style.width = `${pct}%`;
      time.textContent = fmt(audio.currentTime);
    });
    // Placeholder clips may 404 — disable the control rather than look broken.
    audio.addEventListener("error", () => {
      btn.disabled = true;
    });
  });
</script>
