# Augova — environment variables (spec §11/§14). Copy to .env for local dev
# (astro dev proxies Pages Functions) and set the same keys as Cloudflare
# Pages env vars for deploys. Every value below is a [[PLACEHOLDER]] until
# the team supplies the real one — the site builds and runs without them,
# the gated features just no-op.

# Cloudflare Turnstile (LeadForm widget + server-side verification)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Lead email (functions/submit.js — defaults to Resend, swappable)
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=leads@augova.com
ZOHO_INBOX_EMAIL=

# Leads-tracker webhook (functions/submit.js) — same pipeline as outreach leads
LEADS_WEBHOOK_URL=

# Cal.com inline embed (src/pages/demo.astro)
PUBLIC_CAL_COM_LINK=

# Live demo number, tel: link (src/pages/index.astro §7.4)
PUBLIC_DEMO_NUMBER=

# Cloudflare Web Analytics beacon token (src/layouts/BaseLayout.astro)
CF_WEB_ANALYTICS_TOKEN=
